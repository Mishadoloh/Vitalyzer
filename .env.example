# Скопіюйте цей файл у .env і за потреби відредагуйте.
# Значення за замовчуванням підходять для docker-compose.yml, що йде в комплекті.
DATABASE_URL="postgresql://vitalyzer:vitalyzer@localhost:5432/vitalyzer?schema=public"

# --- Автентифікація (NextAuth + Google) ---
# https://console.cloud.google.com/apis/credentials → створіть OAuth Client ID
# (тип "Web application"). Додайте точні Authorized redirect URI:
# http://localhost:3000/api/auth/callback/google
# http://localhost:3008/api/auth/callback/google (якщо запускаєте через --port 3008)
# https://vitalyzer.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Публічна адреса застосунку (для колбеків NextAuth і Stripe).
NEXTAUTH_URL="http://localhost:3000"
# Згенеруйте випадковий секрет: `openssl rand -base64 32`
NEXTAUTH_SECRET=""

# Код підтвердження власності з Google Search Console (без тегів HTML).
GOOGLE_SITE_VERIFICATION=""

# --- Email-розсилка ---
# Якщо RESEND_API_KEY порожній, застосунок формує preview листа в логах без реальної відправки.
RESEND_API_KEY=""
EMAIL_FROM="Vitalyzer <onboarding@resend.dev>"
# Для автоматичної розсилки викликайте: /api/email-digest?secret=<EMAIL_CRON_SECRET>
EMAIL_CRON_SECRET=""

# --- Підписка (Stripe) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Створіть продукт/ціну (Products → Add product, recurring) і вставте Price ID сюди.
STRIPE_PRICE_ID=""
# Отримайте після налаштування webhook-ендпоінта (https://dashboard.stripe.com/webhooks,
# URL: <NEXTAUTH_URL>/api/stripe/webhook) або через `stripe listen` для локальної розробки.
STRIPE_WEBHOOK_SECRET=""

# Текст ціни, який показується на лендингу й сторінці підписки (лише косметично).
# Символ $ обов'язково екранується зворотним слешем — інакше Next.js спробує
# розкрити "$4" як змінну оточення при завантаженні .env.
NEXT_PUBLIC_SUBSCRIPTION_PRICE_LABEL="\$4.99 / місяць"
